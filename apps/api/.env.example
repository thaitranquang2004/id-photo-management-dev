NODE_ENV=development
PORT=4000
# Allowed CORS origin for the web app. '*' is for local dev only and is REJECTED at
# startup when NODE_ENV=production — set the real web URL there (comma-separated for many).
CORS_ORIGIN=*

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Text+vision model used for the automated quality-check (Phase A). Best-effort.
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash

# Notifications (Phase C). All optional: without SMTP, email degrades to log-only
# ("simulated"); Zalo is always simulated (logged). NOTIFICATIONS_ENABLED=false makes
# every channel log-only. WEB_BASE_URL is used to build the tokened lookup link.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=Tiệm hình thẻ <no-reply@tiemhinhthe.local>
NOTIFICATIONS_ENABLED=true

# Tự động xoá ảnh Cloudinary của đơn cũ hơn 6 tháng (chạy nền hằng ngày 03:00).
ASSET_PURGE_ENABLED=true
WEB_BASE_URL=http://localhost:5173

SIGNED_URL_PUBLIC_TTL_SECONDS=86400
SIGNED_URL_INTERNAL_TTL_SECONDS=900
PUBLIC_LOOKUP_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_LOOKUP_RATE_LIMIT_MAX=20
